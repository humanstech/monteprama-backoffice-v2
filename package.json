{
	"name": "starter",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"preinstall": "npx only-allow pnpm",
		"types": "tsc -b",
		"lint": "pnpx ultracite fix",
		"validate": "pnpm types && pnpm lint",
		"i18n:check-duplicates": "node scripts/i18n/check-duplicates.js",
		"i18n:sort-keys": "node scripts/i18n/sort-keys.js",
		"i18n:generate-missing": "node scripts/i18n/generate-missing.js",
		"i18n:validate": "pnpm i18n:sort-keys && pnpm i18n:check-duplicates",
		"dev": "vite",
		"build": "pnpm validate && vite build",
		"preview": "vite preview",
		"prepare": "husky"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@hookform/resolvers": "^5.2.2",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-query-devtools": "^5.91.3",
		"axios": "^1.13.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"date-fns-tz": "^3.2.0",
		"i18next": "^25.8.9",
		"i18next-browser-languagedetector": "^8.2.1",
		"i18next-http-backend": "^3.0.2",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.7.0",
		"next-themes": "^0.4.6",
		"radix-ui": "latest",
		"react": "^19.2.4",
		"react-day-picker": "9.13.2",
		"react-dom": "^19.2.4",
		"react-error-boundary": "^6.1.1",
		"react-hook-form": "^7.71.1",
		"react-i18next": "^16.5.4",
		"react-router": "^7.13.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.1",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6",
		"zustand": "^5.0.11"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.0",
		"@types/node": "^25.2.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"shadcn": "^3.8.4",
		"typescript": "~5.9.3",
		"ultracite": "7.2.2",
		"vite": "^7.3.1"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
			"pnpm validate"
		],
		"src/translations/**/*.json": [
			"pnpm i18n:validate"
		]
	}
}
