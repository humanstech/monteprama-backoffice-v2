{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"extends": ["ultracite/biome/core", "ultracite/biome/react"],
	"files": {
		"includes": ["!icons-source.tsx"]
	},
	"formatter": {
		"indentWidth": 4,
		"indentStyle": "tab"
	},
	"javascript": {
		"formatter": {
			"semicolons": "asNeeded",
			"trailingCommas": "none",
			"quoteStyle": "single",
			"jsxQuoteStyle": "single"
		}
	},
	"json": {
		"formatter": {
			"indentWidth": 4,
			"indentStyle": "tab"
		}
	}
}
